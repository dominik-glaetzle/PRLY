{
  "expo": {
    "name": "PRLY",
    "slug": "PRLY",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-light.png",
    "scheme": "prly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/ios-light.png",
      "bundleIdentifier": "com.smxkz.PRLY",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "38cca733-019f-4628-83a4-d20b17ce6a6a"
      }
    }
  }
}
